#!/bin/zsh

set -e

eval "$(
argparse.sh \
	--ours ">repl" "Choose our git hunks" \
	--theirs ">repl" "Choose their git hunks" \
	-p --preview "Do not apply changes" \
	--debug "Debug mode" \
	"[...files]"
)"

if [ ! "$repl" ]; then
	argparse_usage "$0"
	exit 1
fi

if [ "$repl" = "ours" ]; then
	repl='$1'
else
	repl='$2'
fi

if [ "$debug" ]; then
	set -x
fi

root_dir="$(git rev-parse --show-toplevel)"

regex='<<<<<<< (?:HEAD|Updated upstream)\n([\s\S]*?)(?:\|\|\|\|\|\|\| (?:parent of|Stash base)[\s\S]*?)?=======\n([\s\S]*?)>>>>>>> .*\n'

(
	if [ "$#" -eq 0 ]; then
		git status --porcelain | rg UU | cut -c4-
	else
		for arg; do echo "$arg"; done
	fi
) | while read -r file; do
	[ "$#" -eq 0 ] && cd "$root_dir"
	if [ "$preview" ]; then
		git diff --no-index -- <(git show HEAD:"$file") <(sd -A -p "$regex" "$repl" "$file")
	else
		sd -A "$regex" "$repl" "$file"
		git add "$file"
	fi
done
