#!/bin/zsh

usage() {
	echo "usage: git accept <--ours|--theirs> [file...]"
}

repl=""
preview=""

for arg; do
	case "$arg" in
	-h|--help)
		usage
		exit 0
		;;
	--debug)
		set -x
		shift
		;;
	--ours)
		repl='$1'
		shift
		;;
	--theirs)
		repl='$2'
		shift
		;;
	-p|--preview)
		preview="yes"
		shift
		;;
	--*)
		usage
		exit 1
		;;
	*)
		set -- "$@" "$arg"
		shift
		;;
	esac
done

if [ "$repl" = "" ]; then
	usage
	exit 1
fi

root_dir="$(git rev-parse --show-toplevel)"

regex='<<<<<<< (?:HEAD|Updated upstream)\n([\s\S]*?)(?:\|\|\|\|\|\|\| (?:parent of|Stash base)[\s\S]*?)?=======\n([\s\S]*?)>>>>>>> .*\n'

(
	if [ "$#" -eq 0 ]; then
		git status --porcelain | rg UU | cut -c4-
	else
		for arg; do echo "$arg"; done
	fi
) | while read -r file; do
	[ "$#" -eq 0 ] && cd "$root_dir"
	if [ "$preview" ]; then
		git diff --no-index -- <(git show HEAD:"$file") <(sd -A -p "$regex" "$repl" "$file")
	else
		sd -A "$regex" "$repl" "$file"
		git add "$file"
	fi
done
